<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Projekt2.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400"
             x:Class="Projekt2.Views.TransportView"
             x:DataType="vm:TransportViewModel">

    <StackPanel Margin="30" Spacing="15" Background="White">
        <TextBlock Text="Transport" FontSize="28" FontWeight="Bold" Foreground="Black"/>
        <TextBlock Text="Wybierz sposob dostawy:" FontSize="16" Foreground="#333"/>

        <Border Background="#f5f5f5" CornerRadius="8" Padding="25">
            <StackPanel Spacing="15">
                <CheckBox IsChecked="{Binding IsInpost}" Foreground="Black" FontSize="16">
                    <TextBlock Text="Kurier InPost" Foreground="Black"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding IsDpd}" Foreground="Black" FontSize="16">
                    <TextBlock Text="Kurier DPD" Foreground="Black"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding IsFedex}" Foreground="Black" FontSize="16">
                    <TextBlock Text="Kurier FedEx" Foreground="Black"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding IsNaMiejscu}" Foreground="Black" FontSize="16">
                    <TextBlock Text="Na miejscu" Foreground="Black"/>
                </CheckBox>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Zatwierdz" Command="{Binding ZatwierdzCommand}"
                    Background="#27ae60" Foreground="White"
                    Padding="25,12" FontSize="14"/>
            <Button Content="Anuluj" Command="{Binding AnulujCommand}"
                    Background="#e74c3c" Foreground="White"
                    Padding="25,12" FontSize="14"/>
        </StackPanel>
    </StackPanel>

</UserControl>
