<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Projekt2.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Projekt2.Views.KoszykView"
             x:DataType="vm:KoszykViewModel">

    <Grid ColumnDefinitions="*,200" Background="White">

        <DockPanel Grid.Column="0" Margin="20">
            <TextBlock Text="Koszyk" FontSize="24" FontWeight="Bold" Foreground="Black"
                       DockPanel.Dock="Top" Margin="0,0,0,15"/>
            <ListBox ItemsSource="{Binding KoszykItems}"
                     SelectionMode="Single" IsHitTestVisible="True"
                     Foreground="Black" Background="#fafafa" FontSize="15" Padding="5">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="IsHitTestVisible" Value="False"/>
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </DockPanel>

        <Border Grid.Column="1" Background="#e8e8e8" Padding="15"
                BorderBrush="#ccc" BorderThickness="1,0,0,0">
            <StackPanel Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Przejdz do:" FontSize="14" FontWeight="Bold" Foreground="Black"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Button Content="Sklep" Command="{Binding GoToSklepCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10,12" FontSize="14"/>

                <Button Command="{Binding GoToTransportCommand}"
                        Background="{Binding TransportButtonColor}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10,12" FontSize="14">
                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="&#x2713;" IsVisible="{Binding TransportVm.IsTransportWybrany}"
                                   FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Transport"/>
                    </StackPanel>
                </Button>

                <Button Content="Platnosc" Command="{Binding GoToPlatnoscCommand}"
                        IsEnabled="{Binding TransportVm.IsTransportWybrany}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10,12" FontSize="14"/>

            </StackPanel>
        </Border>

    </Grid>

</UserControl>
