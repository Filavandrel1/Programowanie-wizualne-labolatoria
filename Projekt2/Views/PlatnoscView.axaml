<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Projekt2.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400"
             x:Class="Projekt2.Views.PlatnoscView"
             x:DataType="vm:PlatnoscViewModel">

    <StackPanel Margin="30" Spacing="15" Background="White">
        <TextBlock Text="Platnosc" FontSize="28" FontWeight="Bold" Foreground="Black"/>
        <TextBlock Text="Wybierz metode platnosci:" FontSize="16" Foreground="#333" Margin="0,10,0,0"/>

        <RadioButton GroupName="Platnosc" IsChecked="{Binding IsBlik}" Foreground="Black" FontSize="16">
            <TextBlock Text="Blik" Foreground="Black"/>
        </RadioButton>
        <RadioButton GroupName="Platnosc" IsChecked="{Binding IsKarta}" Foreground="Black" FontSize="16">
            <TextBlock Text="Karta" Foreground="Black"/>
        </RadioButton>
        <RadioButton GroupName="Platnosc" IsChecked="{Binding IsGotowka}" Foreground="Black" FontSize="16">
            <TextBlock Text="Gotowka" Foreground="Black"/>
        </RadioButton>

        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,20,0,0">
            <Button Content="Zaplac" Command="{Binding ZaplacCommand}"
                    IsEnabled="{Binding IsPlatnoscWybrana}"
                    Background="#4CAF50" Foreground="White" FontSize="16"
                    Padding="20,10" CornerRadius="5"/>
            <Button Content="Anuluj" Command="{Binding AnulujCommand}"
                    Background="#f44336" Foreground="White" FontSize="16"
                    Padding="20,10" CornerRadius="5"/>
        </StackPanel>
    </StackPanel>

</UserControl>
