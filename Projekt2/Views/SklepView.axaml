<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Projekt2.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Projekt2.Views.SklepView"
             x:DataType="vm:SklepViewModel">

    <DockPanel Margin="20" Background="White">

        <TextBlock Text="Sklep" FontSize="24" FontWeight="Bold" Foreground="Black"
                   DockPanel.Dock="Top" Margin="0,0,0,15"/>

        <!-- Przyciski na dole -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    Spacing="10" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Dodaj do koszyka" Command="{Binding DodajCommand}"
                    CommandParameter="{Binding #ProduktyList.SelectedItems}"
                    Background="#27ae60" Foreground="White"
                    Padding="20,10" FontSize="14"/>
            <Button Content="Anuluj" Command="{Binding AnulujCommand}"
                    Background="#e74c3c" Foreground="White"
                    Padding="20,10" FontSize="14"/>
        </StackPanel>

        <!-- Lista produktow (multiselect) -->
        <ListBox x:Name="ProduktyList"
                 ItemsSource="{Binding Produkty}"
                 SelectionMode="Multiple"
                 Foreground="Black" Background="#fafafa" FontSize="15" Padding="5">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </ListBox.Styles>
        </ListBox>

    </DockPanel>

</UserControl>
